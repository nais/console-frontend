{
	"name": "console-frontend",
	"version": "0.0.1",
	"private": true,
	"packageManager": "npm@11.6.1",
	"scripts": {
		"prepare": "svelte-kit sync || echo ''",
		"allow-scripts": "allow-scripts",
		"dev": "vite dev",
		"dev-live-share": "vite dev --host ::",
		"build": "vite build",
		"preview": "vite preview",
		"check": "npx houdini generate && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"eslint": "eslint .",
		"format": "prettier --write .",
		"check-outdated": "node check-updates-cooldown.mjs",
		"update-outdated": "node check-updates-cooldown.mjs --install",
		"check-age": "node check-package-age.mjs",
		"install-safe": "npx npq install",
		"test": "vitest",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"upgrade-storybook": "node upgrade-storybook.mjs",
		"lint-staged": "lint-staged",
		"lockfile-lint": "lockfile-lint --path package-lock.json"
	},
	"devDependencies": {
		"@chromatic-com/storybook": "5.0.2",
		"@eslint/compat": "2.0.3",
		"@eslint/js": "10.0.1",
		"@lavamoat/allow-scripts": "4.0.0",
		"@lavamoat/preinstall-always-fail": "3.0.0",
		"@layerstack/utils": "2.0.0-next.18",
		"@nais/ds-svelte-community": "2.0.0-next.6",
		"@storybook/addon-docs": "10.3.3",
		"@storybook/addon-svelte-csf": "5.0.11",
		"@storybook/addon-themes": "10.3.3",
		"@storybook/sveltekit": "10.3.3",
		"@sveltejs/adapter-node": "5.5.4",
		"@sveltejs/kit": "2.57.1",
		"@sveltejs/vite-plugin-svelte": "6.2.4",
		"@tailwindcss/vite": "4.2.2",
		"@types/d3-array": "3.2.2",
		"@types/d3-time": "3.0.4",
		"@types/luxon": "3.7.1",
		"@types/sortablejs": "1.15.9",
		"date-fns": "4.1.0",
		"eslint": "10.1.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-storybook": "10.3.3",
		"eslint-plugin-svelte": "3.16.0",
		"eslint-plugin-unicorn": "63.0.0",
		"globals": "17.4.0",
		"houdini": "2.0.0-next.11",
		"houdini-svelte": "3.0.0-next.13",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"lockfile-lint": "5.0.0",
		"npm-check-updates": "19.6.5",
		"npq": "3.16.1",
		"pino-pretty": "13.1.3",
		"prettier": "3.8.1",
		"prettier-plugin-svelte": "3.5.1",
		"prettier-plugin-tailwindcss": "0.7.2",
		"semver": "7.7.4",
		"storybook": "10.3.3",
		"svelte": "5.55.0",
		"svelte-check": "4.4.5",
		"tailwindcss": "4.2.2",
		"typescript": "5.9.3",
		"typescript-eslint": "8.57.2",
		"vite": "7.3.2",
		"vitest": "4.1.0"
	},
	"type": "module",
	"dependencies": {
		"@codemirror/language": "6.12.2",
		"@codemirror/state": "6.6.0",
		"@codemirror/theme-one-dark": "6.1.3",
		"@codemirror/view": "6.40.0",
		"@prometheus-io/codemirror-promql": "0.308.0",
		"@slack/types": "2.20.1",
		"@slack/web-api": "7.15.0",
		"cron-parser": "5.5.0",
		"cronstrue": "3.14.0",
		"graphql": "16.13.1",
		"graphql-sse": "2.6.0",
		"layerchart": "2.0.0-next.46",
		"luxon": "3.7.2",
		"pino": "10.3.1",
		"pretty-bytes": "7.1.0",
		"sortablejs": "1.15.7",
		"svelte-highlight": "7.9.0",
		"yaml": "2.8.3"
	},
	"overrides": {
		"@sveltejs/kit": {
			"cookie": "^0.7.0"
		}
	},
	"lint-staged": {
		"*.{js,ts,svelte,gql,css,md,json}": "prettier --write",
		"*.{js,ts,svelte,gql}": [
			"eslint --fix",
			"svelte-check --tsconfig ./tsconfig.json --fail-on-warnings"
		]
	},
	"graphql": {
		"schema": "https://localhost:3000/graphql",
		"documents": "**/*.{graphql,js,ts,jsx,tsx,svelte}"
	},
	"lavamoat": {
		"allowScripts": {
			"@lavamoat/preinstall-always-fail": false,
			"vite>esbuild": true
		}
	}
}
