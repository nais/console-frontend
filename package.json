{
	"name": "console-frontend",
	"version": "0.0.1",
	"private": true,
	"packageManager": "pnpm@11.3.0",
	"scripts": {
		"build": "vite build",
		"check-age": "node check-package-age.mjs",
		"check-outdated": "node check-updates-cooldown.mjs",
		"check:watch": "svelte-check --tsconfig ./tsconfig.json --watch",
		"check": "pnpm exec houdini generate && svelte-check --tsconfig ./tsconfig.json --fail-on-warnings",
		"dev-live-share": "vite dev --host ::",
		"dev": "vite dev",
		"eslint": "eslint .",
		"format": "prettier --write .",
		"lint-staged": "lint-staged",
		"lint": "prettier --check . && eslint .",
		"prepare": "svelte-kit sync || echo ''",
		"preview": "vite preview",
		"test": "vitest",
		"update-outdated": "node check-updates-cooldown.mjs --install"
	},
	"devDependencies": {
		"@eslint/compat": "2.1.0",
		"@eslint/js": "10.0.1",
		"@layerstack/utils": "2.0.0-next.18",
		"@nais/ds-svelte-community": "2.0.0-next.8",
		"@sveltejs/adapter-node": "5.5.4",
		"@sveltejs/kit": "2.60.1",
		"@sveltejs/vite-plugin-svelte": "7.1.2",
		"@tailwindcss/vite": "4.3.0",
		"@types/d3-array": "3.2.2",
		"@types/d3-time": "3.0.4",
		"@types/luxon": "3.7.1",
		"@types/sortablejs": "1.15.9",
		"date-fns": "4.2.1",
		"eslint": "10.4.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.17.1",
		"eslint-plugin-unicorn": "64.0.0",
		"globals": "17.6.0",
		"houdini": "2.0.0-next.12",
		"houdini-svelte": "3.0.0-next.14",
		"husky": "9.1.7",
		"lint-staged": "17.0.5",
		"pino-pretty": "13.1.3",
		"prettier": "3.8.3",
		"prettier-plugin-svelte": "3.5.2",
		"prettier-plugin-tailwindcss": "0.8.0",
		"semver": "7.8.0",
		"svelte": "5.55.9",
		"svelte-check": "4.4.8",
		"tailwindcss": "4.3.0",
		"typescript": "6.0.3",
		"typescript-eslint": "8.59.4",
		"vite": "8.0.13",
		"vitest": "4.1.6"
	},
	"type": "module",
	"dependencies": {
		"@codemirror/language": "6.12.3",
		"@codemirror/state": "6.6.0",
		"@codemirror/theme-one-dark": "6.1.3",
		"@codemirror/view": "6.43.0",
		"@prometheus-io/codemirror-promql": "0.311.3",
		"@slack/types": "2.21.1",
		"@slack/web-api": "7.16.0",
		"cron-parser": "5.5.0",
		"cronstrue": "3.14.0",
		"d3-array": "3.2.4",
		"d3-time": "3.1.0",
		"graphql": "16.14.0",
		"graphql-sse": "2.6.0",
		"layerchart": "2.0.0-next.64",
		"luxon": "3.7.2",
		"pino": "10.3.1",
		"pretty-bytes": "7.1.0",
		"sortablejs": "1.15.7",
		"svelte-highlight": "7.9.0",
		"yaml": "2.9.0"
	},
	"lint-staged": {
		"*.{js,ts,svelte,gql,css,md,json}": "prettier --write",
		"*.{js,ts,svelte,gql}": [
			"eslint --fix",
			"svelte-check --tsconfig ./tsconfig.json --fail-on-warnings"
		]
	},
	"graphql": {
		"schema": "https://localhost:3000/graphql",
		"documents": "**/*.{graphql,js,ts,jsx,tsx,svelte}"
	}
}
